{
  "name": "medlink",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "start:tunnel": "expo start --tunnel",
    "share:review": "expo start --tunnel",
    "android": "expo start --android",
